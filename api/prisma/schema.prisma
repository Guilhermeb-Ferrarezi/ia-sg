generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id                Int            @id @default(autoincrement())
  waId              String         @unique
  name              String?
  email             String?
  stageId           Int?
  stage             PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  leadStatus        String         @default("open")
  source            String?
  notes             String?
  botEnabled        Boolean        @default(true)
  customBotPersona  String?
  aiSummary         String?
  age               String?
  level             String?
  objective         String?
  interestedCourse  String?
  courseMode        String?
  availability      String?
  interestConfidence Float?
  qualificationScore Int?
  handoffNeeded     Boolean        @default(false)
  lastLandingSentAt DateTime?
  lastLandingOfferId Int?
  lastLandingPageId Int?
  lastInteractionAt DateTime?
  createdAt         DateTime       @default(now())
  messages          Message[]
  tasks             Task[]
  tags              ContactTag[]
  landingDeliveries LandingDelivery[]

  @@index([stageId])
  @@index([leadStatus])
  @@index([handoffNeeded])
  @@index([qualificationScore])
  @@index([lastInteractionAt])
  @@index([lastLandingOfferId])
  @@index([lastLandingPageId])
}

model Message {
  id          Int      @id @default(autoincrement())
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  direction   String   // "in" | "out"
  body        String
  waMessageId String?
  createdAt   DateTime @default(now())

  @@index([contactId, createdAt])
  @@unique([contactId, waMessageId])
}

model Faq {
  id        Int      @id @default(autoincrement())
  question  String   @unique
  answer    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model PipelineStage {
  id              Int       @id @default(autoincrement())
  name            String    @unique
  position        Int       @unique
  color           String    @default("#06b6d4")
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  contacts        Contact[]
}

model Task {
  id          Int      @id @default(autoincrement())
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueAt       DateTime
  status      String   @default("open")
  priority    String   @default("medium")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  @@index([contactId, status])
  @@index([dueAt, status])
}

model MessageTemplate {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  category  String   @default("geral")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model Tag {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  color     String       @default("#06b6d4")
  createdAt DateTime     @default(now())
  contacts  ContactTag[]
}

model ContactTag {
  id        Int      @id @default(autoincrement())
  contactId Int
  tagId     Int
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
}

model AiConfig {
  key                  String   @id @default("default")
  model                String
  baseUrl              String
  transcriptionModel   String
  persona              String   @default("")
  historyLimit         Int      @default(20)
  aiReplyDebounceMs    Int      @default(0)
  humanDelayMinMs      Int      @default(1200)
  humanDelayMaxMs      Int      @default(6500)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Offer {
  id                Int                  @id @default(autoincrement())
  title             String
  slug              String               @unique
  aliases           Json?
  durationLabel     String?
  modality          String?
  shortDescription  String?
  approvedFacts     Json?
  ctaLabel          String
  ctaUrl            String
  visualTheme       String?
  isActive          Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  landingPages      LandingPage[]
  promptConfigs     LandingPromptConfig[]
  landingDeliveries LandingDelivery[]

  @@index([isActive])
  @@index([title])
}

model LandingPromptConfig {
  id             Int       @id @default(autoincrement())
  scope          String
  offerId        Int?
  offer          Offer?    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  systemPrompt   String
  toneGuidelines String?
  requiredRules  Json?
  ctaRules       Json?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([scope, active])
  @@index([offerId, active])
}

model LandingPage {
  id                  Int               @id @default(autoincrement())
  offerId             Int
  offer               Offer             @relation(fields: [offerId], references: [id], onDelete: Cascade)
  version             Int
  status              String            @default("draft")
  sectionsJson        Json
  promptSnapshot      Json?
  sourceFactsSnapshot Json?
  publishedAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deliveries          LandingDelivery[]

  @@unique([offerId, version])
  @@index([offerId, status])
  @@index([publishedAt])
}

model LandingDelivery {
  id             Int           @id @default(autoincrement())
  contactId      Int
  offerId        Int
  landingPageId  Int
  token          String        @unique
  deliveryChannel String       @default("whatsapp")
  sentAt         DateTime      @default(now())
  lastViewedAt   DateTime?
  lastClickedAt  DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  contact        Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  offer          Offer         @relation(fields: [offerId], references: [id], onDelete: Cascade)
  landingPage    LandingPage   @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  events         LandingEvent[]

  @@index([contactId, offerId])
  @@index([offerId, sentAt])
  @@index([landingPageId])
}

model LandingEvent {
  id          Int             @id @default(autoincrement())
  deliveryId  Int
  eventType   String
  requestMeta Json?
  userAgent   String?
  ip          String?
  referrer    String?
  createdAt   DateTime        @default(now())
  delivery    LandingDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId, eventType])
  @@index([createdAt])
}

model WebhookEvent {
  id           Int      @id @default(autoincrement())
  requestId    String
  waId         String?
  waMessageId  String?
  dedupeKey    String   @unique
  payload      Json
  status       String   @default("pending")
  attemptCount Int      @default(0)
  nextAttemptAt DateTime?
  lockedAt     DateTime?
  processedAt  DateTime?
  lastError    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([waMessageId])
  @@index([createdAt])
}

model AppLog {
  id             Int      @id @default(autoincrement())
  ts             DateTime @default(now())
  level          String
  event          String
  method         String?
  path           String?
  statusCode     Int?
  durationMs     Int?
  ip             String?
  userAgent      String?
  clientOs       String?
  requestId      String?
  waId           String?
  contactId      Int?
  webhookEventId Int?
  message        String?
  data           Json?

  @@index([ts])
  @@index([level])
  @@index([event])
  @@index([method])
  @@index([path])
  @@index([statusCode])
  @@index([clientOs])
  @@index([requestId])
  @@index([waId])
  @@index([contactId])
}
